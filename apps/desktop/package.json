{
  "name": "pilotdeck-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform Electron shell for PilotDeck.",
  "author": "PilotDeck",
  "main": "dist/main.js",
  "scripts": {
    "build:runtime": "node scripts/build-runtime.mjs",
    "compile": "tsc -p tsconfig.json",
    "dev": "node scripts/build-runtime.mjs && tsc -p tsconfig.json && electron .",
    "pack": "node scripts/build-runtime.mjs && tsc -p tsconfig.json && electron-builder --dir",
    "dist:mac": "node scripts/build-runtime.mjs && tsc -p tsconfig.json && electron-builder --mac",
    "dist:win": "node scripts/build-runtime.mjs && tsc -p tsconfig.json && electron-builder --win",
    "download-node": "node scripts/download-node.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.0.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "cn.pilotdeck.desktop",
    "productName": "PilotDeck",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "compression": "maximum",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      {
        "from": ".",
        "filter": [
          "dist/**/*",
          "package.json",
          "!node_modules/**/*"
        ]
      }
    ],
    "asar": true,
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "afterPack": "scripts/after-pack.cjs",
    "extraMetadata": {
      "dependencies": {}
    },
    "extraResources": [
      {
        "from": "resources/node",
        "to": "node"
      },
      {
        "from": ".runtime/app",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
